{
  "name": "vessel-v3",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "dev:watch": "node scripts/dev-monitor.js",
    "dev:raw": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "dev:turbo": "next dev --turbo",
    "dev:memory": "WEBPACK_CACHE_TYPE=memory next dev",
    "dev:safe": "WEBPACK_CACHE_TYPE=memory WSL_DISTRO_NAME=1 next dev",
    "build": "node scripts/next-build.mjs",
    "build:github": "npm run build && touch out/.nojekyll",
    "build:goblet-inline": "node scripts/build-goblet-runtime.mjs",
    "build:align-fit": "node scripts/build-align-fit.mjs",
    "prebuild:github": "npm run cache:clear && npm run build:align-fit && npm run build:goblet-inline",
    "start": "next start",
    "preview": "node scripts/preview-server.mjs",
    "preview:prod": "PORT=3001 node scripts/preview-server.mjs",
    "lint": "next lint",
    "test": "jest",
    "test:e2e:load-project-modal": "playwright test tests/load-project-modal.spec.ts --reporter=line",
    "test:load-project-modal:guardrails": "jest --runInBand LoadProjectModal projectIO",
    "test:load-project-modal:perf": "jest --runInBand src/components/modals/__tests__/LoadProjectModal.perf.smoke.test.tsx",
    "perf:sequential": "jest --runInBand src/lib/sequential/__tests__/SequentialPerformance.smoke.test.ts",
    "type-check": "tsc --noEmit",
    "validate:wgsl": "node scripts/validate-wgsl.mjs",
    "cache:clear": "rm -rf .next node_modules/.cache .turbo",
    "clean": "rm -rf .next out dist node_modules/.cache .turbo coverage",
    "prebuild": "npm run cache:clear && npm run build:align-fit && npm run build:goblet-inline",
    "commit": "node scripts/auto-commit.js",
    "cc": "clear && node scripts/auto-commit.js"
  },
  "dependencies": {
    "@heroui/react": "^2.8.2",
    "@heroui/slider": "^2.4.21",
    "@heroui/system": "^2.4.20",
    "@heroui/theme": "^2.4.20",
    "@radix-ui/react-slider": "^1.3.5",
    "@tailwindcss/postcss": "^4.1.11",
    "fflate": "^0.8.2",
    "framer-motion": "^12.23.12",
    "gifenc": "^1.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.536.0",
    "next": "^15.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jszip": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@webgpu/types": "^0.1.65",
    "eslint": "^9",
    "eslint-config-next": "15.3.4",
    "jest": "^29",
    "jest-environment-jsdom": "^30.0.4",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}

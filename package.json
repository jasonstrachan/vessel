{
  "name": "vessel-v3",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "dev:watch": "node scripts/dev-monitor.js",
    "dev:raw": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "dev:turbo": "next dev --turbo",
    "dev:memory": "WEBPACK_CACHE_TYPE=memory next dev",
    "dev:safe": "WEBPACK_CACHE_TYPE=memory WSL_DISTRO_NAME=1 next dev",
    "build": "NEXT_DIST_DIR=.next-build node scripts/next-build.mjs",
    "build:clean": "rm -rf .next-build .next-preview out node_modules/.cache .turbo && npm run build:align-fit && npm run build:goblet-inline && NEXT_DIST_DIR=.next-build node scripts/next-build.mjs",
    "build:github": "npm run build:clean && touch out/.nojekyll",
    "build:goblet-inline": "node scripts/build-goblet-runtime.mjs",
    "verify:goblet2-inline": "node scripts/build-goblet-runtime.mjs --check --target=goblet2",
    "build:align-fit": "node scripts/build-align-fit.mjs",
    "prebuild:github": "npm run build:align-fit && npm run build:goblet-inline",
    "start": "NEXT_DIST_DIR=.next-build next start",
    "preview": "node scripts/preview-server.mjs",
    "preview:prod": "npm run preview:prod:build && npm run preview:prod:stop && npm run preview:prod:serve",
    "preview:prod:build": "node scripts/preview-build.mjs",
    "preview:prod:serve": "PREVIEW_OUT_DIR=.next-preview PORT=3001 node scripts/preview-server.mjs",
    "preview:prod:status": "PORT=3001 node scripts/preview-port.mjs status",
    "preview:prod:stop": "PORT=3001 node scripts/preview-port.mjs stop",
    "preview:prod:restart": "npm run preview:prod",
    "lint": "eslint src",
    "audit:prod": "npm audit --omit=dev",
    "audit:full": "npm audit",
    "audit:full:json": "npm audit --json > audit-full.json || true",
    "audit:full:summary": "node scripts/audit-summary.mjs audit-full.json audit-full-summary.md",
    "test": "jest",
    "test:e2e:load-project-modal": "playwright test tests/load-project-modal.spec.ts --reporter=line",
    "test:goblet2:single-file-smoke": "playwright test tests/goblet2-single-file-smoke.spec.ts --reporter=line",
    "test:load-project-modal:guardrails": "jest --runInBand LoadProjectModal projectIO",
    "test:load-project-modal:perf": "jest --runInBand src/components/modals/__tests__/LoadProjectModal.perf.smoke.test.tsx",
    "perf:sequential": "jest --runInBand src/lib/sequential/__tests__/SequentialPerformance.smoke.test.ts",
    "type-check": "tsc --noEmit",
    "type-check:workers": "tsc --noEmit -p tsconfig.worker.json",
    "type-check:tests": "tsc --noEmit -p tsconfig.test-types.json",
    "architecture:budgets": "node scripts/check-file-budgets.mjs",
    "architecture:console": "node scripts/check-raw-console.mjs --strict",
    "architecture:store-access": "node scripts/check-store-access.mjs --strict",
    "architecture:check": "npm run architecture:budgets && npm run architecture:console && npm run architecture:store-access",
    "validate:wgsl": "node scripts/validate-wgsl.mjs",
    "cache:clear": "rm -rf .next .next-build .next-preview node_modules/.cache .turbo",
    "clean": "rm -rf .next .next-build .next-preview out dist node_modules/.cache .turbo coverage",
    "prebuild": "npm run build:align-fit && npm run build:goblet-inline",
    "commit": "node scripts/auto-commit.js",
    "cc": "clear && node scripts/auto-commit.js"
  },
  "dependencies": {
    "@heroui/react": "^2.8.2",
    "@heroui/slider": "^2.4.21",
    "@heroui/system": "^2.4.20",
    "@heroui/theme": "^2.4.20",
    "@radix-ui/react-slider": "^1.3.5",
    "@tailwindcss/postcss": "^4.2.0",
    "fflate": "^0.8.2",
    "framer-motion": "^12.23.12",
    "gifenc": "^1.0.3",
    "jszip": "^3.10.1",
    "lucide-react": "^0.536.0",
    "next": "^15.5.12",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "sharp": "^0.34.2",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/jszip": "^3.1.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@webgpu/types": "^0.1.65",
    "eslint": "^9",
    "eslint-config-next": "15.5.12",
    "jest": "^29",
    "jest-environment-jsdom": "^30.0.4",
    "playwright": "^1.58.2",
    "tailwindcss": "^4.2.0",
    "ts-jest": "^29.4.0",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
